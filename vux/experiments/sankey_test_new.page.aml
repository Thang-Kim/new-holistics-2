Dashboard sankey_test_new {
  title: 'Sankey Test New'
  description: ''''''
  block f1: FilterBlock {
    label: 'This is a Filter Block'
    type: 'text'
    default {
      operator: 'is'
      value: 'default'
    }
  }
  block v4: VizBlock {
    label: 'Name and Parent'
    viz: DataTable {
      dataset: ecommerce_dataset
      fields: [
        VizFieldFull {
          ref: ref('ecommerce_categories', 'name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_categories', 'parent_id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v5: VizBlock {
    label: 'Sum of Cost and Sum of Sales by Month'
    viz: LineChart {
      dataset: ecommerce_dataset
      x_axis: VizFieldFull {
        ref: ref('ecommerce_financial', 'month')
        format {
          type: 'date'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: ref('ecommerce_financial', 'cost')
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E27712'
            color_palette: 'seq-magma'
          }
        }
        series {
          field: VizFieldFull {
            ref: ref('ecommerce_financial', 'sales')
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#18A59E'
            color_palette: 'seq-magma'
          }
        }
      }
    }
  }
  block v6: VizBlock {
    label: 'Untitled Report'
    viz: DataTable {
      dataset: vinhhh_test_activities
      theme {

      }
      fields: [
        VizFieldFull {
          ref: ref('public_activities', 'trackable_type')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('public_activities', 'owner_type')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('public_activities', 'key')
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_rtlz: VizBlock {
    label: 'Source, Target, and Sum of Weight'
    viz: CustomChart {
      dataset: sankey_test
      custom_chart_id: 21692
      field source: VizFieldFull {
        ref: r(sankey_data_csv.source)
        format {
          type: 'text'
        }
      }
      field target: VizFieldFull {
        ref: r(sankey_data_csv.target)
        format {
          type: 'text'
        }
      }
      field volume: VizFieldFull {
        ref: r(sankey_data_csv.weight)
        aggregation: 'sum'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      setting margin_top: 10
      setting node_align: 'justify'
      setting node_width: 15
      setting margin_left: 10
      setting margin_right: 10
      setting node_padding: 10
      setting margin_bottom: 10
    }
  }
  block v_6xjx: VizBlock {
    label: 'Source, Target, and Sum of Weight copy'
    viz: DataTable {
      dataset: sankey_test
      fields: [
        VizFieldFull {
          ref: r(sankey_data_csv.source)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(sankey_data_csv.target)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(sankey_data_csv.weight)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
      }
    }
  }
  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      label: 'Tab 1'
      width: 930
      height: 440
      block v_rtlz {
        position: pos(10, 10, 910, 420)
        layer: 2
      }
      block v_6xjx {
        position: pos(0, 450, 910, 240)
        layer: 2
      }
      mobile {
        mode: 'manual'
        block v1
        block filter_block
        block v2
      }
    }
    tab tab2: CanvasLayout {
      label: 'Tab 2'
      height: 800
      grid_size: 20
      mobile {
        mode: 'auto'
      }
      block f1 {
        position: pos(20, 20, 400, 80)
        layer: 1
      }
      block v4 {
        position: pos(440, 20, 620, 420)
        layer: 2
      }
      block v5 {
        position: pos(20, 460, 620, 320)
        layer: 3
      }
      block v6 {
        position: pos(20, 120, 330, 220)
        layer: 4
      }
    }
  }
  theme: H.themes.classic
  interactions: [
    FilterInteraction {
      from: 'v4'
      to: [
        CustomMapping {
          block: 'v5'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v5'
      to: [
        CustomMapping {
          block: 'v4'
          disabled: true
        }
      ]
    }
  ]
}