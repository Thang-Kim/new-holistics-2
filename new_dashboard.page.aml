Dashboard new_dashboard {
  title: 'New Dashboard'
  description: ''''''
  view: CanvasLayout {
    label: 'View 1'
    height: 800
    block f1 {
      position: pos(10, 10, 300, 100)
      layer: 1
    }
  }
  block f1: FilterBlock {
    label: 'asd'
    type: 'field'
    source: FieldFilterSource {
      dataset: d_cities
      field: ref('ecommerce_cities', 'name')
    }
    default {
      operator: 'is'
      value: 'asdasd'
    }
  }
}