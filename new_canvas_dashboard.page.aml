Dashboard new_canvas_dashboard {
  title: 'New Canvas Dashboard'
  description: ''''''
  block v1: VizBlock {
    label: 'asd'
    viz: PivotTable {
      dataset: ecommerce_dataset
      rows: [
        VizFieldFull {
          ref: ref('ecommerce_financial', 'sales')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      columns: [
        VizFieldFull {
          ref: ref('ecommerce_financial', 'month')
          transformation: 'datetrunc month'
          format {
            type: 'date'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: ref('ecommerce_financial', 'cost')
          aggregation: 'sum'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_financial', 'sales')
          aggregation: 'sum'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_with_no_data: true
        show_row_total: true
        show_column_total: true
        show_sub_total: true
        freeze_rows: false
