  block v2: VizBlock {
    label: 'aaa'
    viz: DataTable {
      dataset: activitites
      fields: [
        VizFieldFull {
          ref: ref('public_activities', 'trackable_type')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('public_activities', 'owner_type')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('public_activities', 'parameters')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('public_activities', 'key')
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_average_row: true
        show_sum_row: true
        show_row_number: true
        show_row_with_no_data: true
  // column_width {
