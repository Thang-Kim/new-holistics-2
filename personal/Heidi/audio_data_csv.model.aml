Model audio_data_csv {
  type: 'table'
  label: 'Audio_data_csv'
  description: ''
  data_source_name: 'khai_postgre'
  dimension audio_title {
    label: 'Audio Title'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.audio_title }};;
  }
  dimension channel {
    label: 'Channel'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.channel }};;
  }
  dimension speaker {
    label: 'Speaker'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.speaker }};;
  }
  dimension topic {
    label: 'Topic'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.topic }};;
  }
  dimension url {
    label: 'Url'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.url }};;
  }
  dimension html_iframe_url {
    label: "Html Iframe Url"
    type: "text"
    description: ""
    definition: @sql CONCAT('<iframe src="',  {{ url }}, '"></iframe>');;
  }

  import_source: ImportSource {
    type: 'csv'
    source: 'audio-data.csv'
    uploaded_at: '2025-07-16 10:38:58'
  }
  owner: 'di.hoang@holistics.io'
  table_name: '"public"."persisted_audio_data_csv7"'
}