Dashboard test_another_new_canvas_riyxr {
  title: 'test another new canvas'
  owner: 'tan.nguyen@holistics.io'
  block filter_block: FilterBlock {
    label: 'This is a Filter Block'
    type: 'text'
    default {
      operator: 'is'
      value: 'default'
    }
  }
  block v1: VizBlock {
    label: 'Name and Parent'
    viz: DataTable {
      dataset: ecommerce_dataset
      theme {

      }
      fields: [
        VizFieldFull {
          ref: r(ecommerce_categories.name)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_categories.parent_id)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v2: VizBlock {
    label: 'Sum of Cost and Sum of Sales by Month'
    viz: LineChart {
      dataset: ecommerce_dataset
      x_axis: VizFieldFull {
        ref: r(ecommerce_financial.month)
        format {
          type: 'date'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(ecommerce_financial.cost)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E27712'
            color_palette: 'seq-magma'
          }
        }
        series {
          field: VizFieldFull {
            ref: r(ecommerce_financial.sales)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#18A59E'
            color_palette: 'seq-magma'
          }
        }
      }
    }
  }
  block v3: VizBlock {
    label: 'Untitled Report'
    viz: DataTable {
      dataset: vinhhh_test_activities
      theme {

      }
      fields: [
        VizFieldFull {
          ref: r(public_activities.trackable_type)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(public_activities.owner_type)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(public_activities.key)
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block f1: FilterBlock {
    label: 'This is a Filter Block'
    type: 'text'
    default {
      operator: 'is'
      value: 'default'
    }
  }
  block v4: VizBlock {
    label: 'Name and Parent'
    viz: DataTable {
      dataset: ecommerce_dataset
      fields: [
        VizFieldFull {
          ref: r(ecommerce_categories.name)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_categories.parent_id)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v5: VizBlock {
    label: 'Sum of Cost and Sum of Sales by Month'
    viz: LineChart {
      dataset: ecommerce_dataset
      x_axis: VizFieldFull {
        ref: r(ecommerce_financial.month)
        format {
          type: 'date'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(ecommerce_financial.cost)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E27712'
            color_palette: 'seq-magma'
          }
        }
        series {
          field: VizFieldFull {
            ref: r(ecommerce_financial.sales)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#18A59E'
            color_palette: 'seq-magma'
          }
        }
      }
    }
  }
  block v6: VizBlock {
    label: 'Untitled Report'
    viz: DataTable {
      dataset: vinhhh_test_activities
      theme {

      }
      fields: [
        VizFieldFull {
          ref: r(public_activities.trackable_type)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(public_activities.owner_type)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(public_activities.key)
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  interactions: [
    FilterInteraction {
      from: 'v1'
      to: [
        CustomMapping {
          block: [
            'v4',
            'v5'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v2'
      to: [
        CustomMapping {
          block: [
            'v4',
            'v5'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v3'
      to: [
        CustomMapping {
          block: 'v6'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v4'
      to: [
        CustomMapping {
          block: [
            'v1',
            'v2'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v5'
      to: [
        CustomMapping {
          block: [
            'v1',
            'v2'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'v6'
      to: [
        CustomMapping {
          block: 'v3'
          disabled: true
        }
      ]
    }
  ]
  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      label: 'Tab 1'
      width: 650
      height: 1100
      block v1 {
        position: pos(20, 20, 620, 420)
      }
      block v2 {
        position: pos(20, 450, 620, 320)
      }
      block v3 {
        position: pos(10, 870, 330, 220)
        layer: 1
      }
      block filter_block {
        position: pos(20, 780, 400, 80)
      }
      mobile {
        mode: 'manual'
        block v1
        block filter_block
        block v2
      }
    }
    tab tab2: CanvasLayout {
      label: 'Tab 2'
      height: 800
      grid_size: 20
      block f1 {
        position: pos(20, 20, 400, 80)
        layer: 1
      }
      block v4 {
        position: pos(440, 20, 620, 420)
        layer: 2
      }
      block v5 {
        position: pos(20, 460, 620, 320)
        layer: 3
      }
      block v6 {
        position: pos(20, 120, 330, 220)
        layer: 4
      }
      mobile {
        mode: 'auto'
      }
    }
  }
  theme: H.themes.classic
}