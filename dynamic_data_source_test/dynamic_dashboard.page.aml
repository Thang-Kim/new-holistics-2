Dashboard dynamic_dashboard {
  title: 'Dynamic Dashboard'
  description: ''''''

  block title: TextBlock {
    content: @md # Your title goes here
<font color="#D2D5DF">(Double click to edit)</font>;;
  }
  block v1: VizBlock {
    label: 'cities'
    viz: DataTable {
      dataset: d_cities
      fields: [
        VizFieldFull {
          ref: ref('ecommerce_cities', 'id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_cities', 'name')
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_row_number: true
      }
    }
  }
  view: CanvasLayout {
    label: 'View 1'
    height: 840
    grid_size: 20
    block title {
      position: pos(20, 20, 1160, 120)
    }
    block v1 {
      position: pos(20, 160, 400, 300)
      layer: 1
    }
  }

  theme: H.themes.classic

}