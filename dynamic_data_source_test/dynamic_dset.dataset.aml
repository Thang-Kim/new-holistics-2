Dataset d_cities {
  label: 'Cities (dynamic data source)'
  description: ''
  data_source_name: dynamic_data_source
  models: [
    ecommerce_cities
  ]
  relationships: []
  owner: 'admin@domain.com'
  metric asdasd {
    label: "Asdasd"
    type: "number"
    hidden: false
    description: ""
    definition: @aql count(ecommerce_cities.id);;
  }

  always_filter {
    filter1: {
      definition: @aql model.name is H.current_user.city ;;
      enabled: true
    }
  }
}