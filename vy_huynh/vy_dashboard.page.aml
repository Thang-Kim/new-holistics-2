Dashboard untitled_4_2 {
  title: 'vy_dashboard'
  description: ''
  owner: 'vy.ht@holistics.io'
  block v_ntre: VizBlock {
    label: 'Date, Category, and Sales'
    viz: DataTable {
      dataset: vy_test
      fields: [
        VizFieldFull {
          ref: r(vy_test_filter_dependency_sheet_1_csv.date)
          format {
            type: 'text'
          }
          uname: 'vy_test_filter_dependency_sheet_1_csv_date_1'
        },
        VizFieldFull {
          ref: r(vy_test_filter_dependency_sheet_1_csv.category)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(vy_test_filter_dependency_sheet_1_csv.sales)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'vy_test_filter_dependency_sheet_1_csv_date_1'
            direction: 'asc'
          }
        ]
      }
    }
  }
  block f_0hsw: FilterBlock {
    label: 'Date'
    type: 'field'
    source: FieldFilterSource {
      dataset: vy_test
      field: r(vy_test_filter_dependency_sheet_1_csv.date)
    }
    default {
      operator: 'matches'
      value: '$H_NIL$'
    }
  }
  block f_o8ba: FilterBlock {
    label: 'Sale'
    type: 'field'
    source: FieldFilterSource {
      dataset: vy_test
      field: r(vy_test_filter_dependency_sheet_1_csv.sales)
    }
    default {
      operator: 'is'
      value: []
    }
  }
  block f_5nfr: FilterBlock {
    label: 'Category'
    type: 'field'
    source: FieldFilterSource {
      dataset: vy_test
      field: r(vy_test_filter_dependency_sheet_1_csv.category)
    }
    default {
      operator: 'is'
      value: []
    }
  }
  block v_7nhj: VizBlock {
    label: 'Count of Audio Title by Topic'
    viz: ColumnChart {
      dataset: audio_dataset
      theme {

      }
      x_axis: VizFieldFull {
        ref: r(audio_data_csv.topic)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(audio_data_csv.audio_title)
            aggregation: 'count'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color_palette: 'seq-magma'
          }
        }
      }
      settings {
        x_axis_show_null_datetime: false
      }
    }
  }
  view: CanvasLayout {
    label: 'View 1'
    width: 1300
    height: 800
    grid_size: 20
    auto_expand_vertically: true
    block v_ntre {
      position: pos(20, 100, 620, 420)
      layer: 1
    }
    block f_0hsw {
      position: pos(20, 0, 300, 80)
      layer: 2
    }
    block f_o8ba {
      position: pos(340, 0, 300, 80)
      layer: 3
    }
    block f_5nfr {
      position: pos(660, 0, 300, 80)
      layer: 4
    }
    block v_7nhj {
      position: pos(660, 100, 620, 420)
      layer: 1
    }
    mobile {
      mode: 'auto'
    }
  }
  theme: H.themes.vanilla
  interactions: [
    FilterInteraction {
      from: 'f_0hsw'
      to: [
        CustomMapping {
          block: 'f_o8ba'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f_o8ba'
      to: [
        CustomMapping {
          block: 'f_0hsw'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f_5nfr'
      to: [
        CustomMapping {
          block: [
            'f_0hsw',
            'f_o8ba'
          ]
          disabled: true
        }
      ]
    }
  ]
}