Model ecommerce_financial {
  type: 'table'
  label: 'Financial'
  description: ''
  data_source_name: 'demodb'
  dimension month {
    label: "Month"
    type: "date"
    definition: @sql {{ #SOURCE.month }};;
    description: "Time month etc"
  }
  dimension sales {
    label: 'Sales'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.sales }};;
  }
  dimension cost {
    label: 'Cost'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.cost }};;
  }
  dimension profit {
    label: 'Profit'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.profit }};;
  }

  owner: 'my.nguyen@holistics.io'
  table_name: '"ecommerce"."financial"'
}
