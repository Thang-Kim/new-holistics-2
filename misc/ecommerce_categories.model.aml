Model ecommerce_categories {
  type: 'table'
  label: 'Categories'
  description: ''
  data_source_name: 'SQLServer'
  dimension id {
    label: 'Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.id }};;
  }
  dimension name {
    label: 'Name'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.name }};;
  }
  dimension parent_id {
    label: 'Parent Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.parent_id }};;
  }
  dimension dim_but_looks_like_metric_count {
    label: 'Dim But Looks Like Metric Count'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.CO2_Per_Capita__metric_tons_ }};;
  }

  owner: 'my.nguyen@holistics.io'
  table_name: '"ecommerce"."categories"'
}
